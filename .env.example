# =============================================================================
# Multi-protocol VPN Server Configuration
#   - wg-easy   (vanilla WireGuard + web UI)
#   - XRAY      (VLESS+Reality, TCP 443)
#   - awg       (AmneziaWG userspace daemon)
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# =============================================================================

# REQUIRED: Server's public IP or domain. Clients connect here for WG and AWG;
# XRAY clients connect to the same host on TCP 443.
WG_HOST=vpn.example.com

# REQUIRED: Bcrypt hash for the wg-easy web UI.
# Generate with:
#   docker run -it ghcr.io/wg-easy/wg-easy wgpw 'YOUR_PASSWORD'
# IMPORTANT: double every $ ($ -> $$) so Compose doesn't interpolate it.
PASSWORD_HASH=

# -----------------------------------------------------------------------------
# Ports (override only if there's a conflict)
# -----------------------------------------------------------------------------
WG_PORT=51820         # wg-easy UDP
WG_UI_PORT=51821      # wg-easy web UI TCP
XRAY_PORT=443         # XRAY VLESS+Reality TCP
AWG_PORT=51822        # AmneziaWG UDP

# -----------------------------------------------------------------------------
# wg-easy defaults pushed to new clients
# -----------------------------------------------------------------------------
WG_DEFAULT_ADDRESS=10.8.0.x
WG_DEFAULT_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0, ::/0
WG_PERSISTENT_KEEPALIVE=25

# -----------------------------------------------------------------------------
# XRAY (VLESS + Reality)
# XRAY itself reads xray/config.json, not .env. The values below are consumed
# by scripts/xray-sync-config.sh, which writes them into xray/config.json.
# Run that script whenever you change one of these values.
# scripts/xray-add-user.sh reads the Reality params back out of config.json
# and derives the matching public key on the fly via 'xray x25519 -i'.
# -----------------------------------------------------------------------------

# Reality private key. Generate with:
#   docker run --rm teddysun/xray xray x25519
# Use the PrivateKey line; the matching PublicKey is not stored separately.
XRAY_REALITY_PRIVATE_KEY=

# Impersonation target — must support TLS 1.3 + X25519. Verify with:
#   openssl s_client -connect <host>:443 -tls1_3 -groups X25519 -servername <host> </dev/null 2>&1 | grep -E 'Protocol|Cipher'
# Battle-tested defaults: www.microsoft.com, www.cloudflare.com, dl.google.com
XRAY_SNI=

# Short ID for the inbound. Generate with:
#   openssl rand -hex 8
XRAY_SHORT_ID=

# -----------------------------------------------------------------------------
# AWG does NOT read from .env — configure directly via awg-data/awg0.conf
# (template: awg/awg0.example.conf). See CLAUDE.md for key generation.
# -----------------------------------------------------------------------------
